    {
      "name": "10 - POST Airbnb listings - Step 1 create listing",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "const listing = json && json.response && json.response.listing;",
              "if (listing && listing.idStr) pm.collectionVariables.set('property_id', String(listing.idStr));",
              "else if (listing && listing.id) pm.collectionVariables.set('property_id', String(listing.id));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "description": "Create a new listing on Airbnb. Step 1 only sends the listing name because it is the only possible field at this stage. The response listing id is saved to the collection property_id variable.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"channelId\": {{channel_id}},\n  \"token\": \"{{token}}\",\n  \"name\": \"Casa de teste em Lumiar A Lisboa\"\n}"
        },
        "url": "{{base_url}}/airbnb-listings"
