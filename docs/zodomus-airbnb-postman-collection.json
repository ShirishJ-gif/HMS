            "{{base_url}}"
          ],
          "path": [
            "airbnb-listings"
          ],
          "query": [
            {
              "key": "token",
              "value": "{{token}}"
            },
            {
              "key": "_limit",
              "value": "50"
            },
            {
              "key": "propertyId",
              "value": "{{property_id}}",
              "disabled": true
            },
            {
              "key": "hasAvailability",
              "value": "false",
              "disabled": true
