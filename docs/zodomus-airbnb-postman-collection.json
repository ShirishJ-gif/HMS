            {
              "key": "excludeActive",
              "value": "true",
              "disabled": true
            },
            {
              "key": "excludeCohostedListings",
              "value": "true",
              "disabled": true
            },
            {
              "key": "_cursor",
              "value": "",
              "disabled": true
            }
          ]
        }
      }
