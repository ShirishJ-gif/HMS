          "raw": "{\n  \"channelId\": {{channel_id}},\n  \"propertyId\": \"{{property_id}}\",\n  \"filename\": \"image1.jpeg\",\n  \"contentType\": \"image/jpeg\",\n  \"category\": \"listing\",\n  \"caption\": \"Living space\",\n  \"image\": \"{{image_base64}}\"\n}"
