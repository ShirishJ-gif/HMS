  "item": [
    {
      "name": "01 - POST Airbnb host activation",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (json.token) pm.collectionVariables.set('token', String(json.token));",
              "if (json.client_id) pm.collectionVariables.set('client_id', String(json.client_id));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"channelId\": {{channel_id}},\n  \"propertyId\": \"{{property_id}}\"\n}"
        },
        "url": "{{base_url}}/airbnb-host-activation"
      }
    },
    {
      "name": "02 - Open Host Authorization URL - Sandbox",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/airbnb-oauth2-tests?client_id={{client_id}}&redirect_uri={{redirect_uri_test}}&scope={{scope}}&state={{token}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "airbnb-oauth2-tests"
          ],
          "query": [
            {
              "key": "client_id",
              "value": "{{client_id}}"
            },
            {
              "key": "redirect_uri",
              "value": "{{redirect_uri_test}}"
            },
            {
              "key": "scope",
              "value": "{{scope}}"
            },
            {
              "key": "state",
              "value": "{{token}}"
            }
          ]
        }
      }
    },
    {
      "name": "03 - Open Host Authorization URL - Production",
      "request": {
        "method": "GET",
        "url": {
          "raw": "https://www.airbnb.com/oauth2/auth?client_id={{client_id}}&redirect_uri={{redirect_uri_production}}&scope={{scope}}&state={{token}}",
          "protocol": "https",
          "host": [
            "www",
            "airbnb",
            "com"
          ],
          "path": [
            "oauth2",
            "auth"
          ],
          "query": [
            {
              "key": "client_id",
              "value": "{{client_id}}"
            },
            {
              "key": "redirect_uri",
              "value": "{{redirect_uri_production}}"
            },
            {
              "key": "scope",
              "value": "{{scope}}"
            },
            {
              "key": "state",
              "value": "{{token}}"
            }
          ]
        }
      }
    },
